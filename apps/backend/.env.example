DATABASE_URL=postgresql://postgres:postgres@localhost:5432/timetravelchat
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9092
# Managed Kafka SASL credentials (leave blank for local dev)
KAFKA_USERNAME=
KAFKA_PASSWORD=
JWT_SECRET=change-me-use-at-least-32-random-characters-in-prod
PORT=4000
NODE_ENV=development
KAFKAJS_NO_PARTITIONER_WARNING=1
# Comma-separated allowed CORS origins (use * for dev)
CORS_ORIGIN=*
